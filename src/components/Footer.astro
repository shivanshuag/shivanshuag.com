---
import { AUTHOR, SOCIALS } from '../consts';

const year = new Date().getFullYear();
const links = [
  SOCIALS.github && { label: 'GitHub', href: SOCIALS.github },
  SOCIALS.linkedin && { label: 'LinkedIn', href: SOCIALS.linkedin },
  SOCIALS.twitter && { label: 'Twitter', href: SOCIALS.twitter },
  SOCIALS.email && { label: 'Email', href: `mailto:${SOCIALS.email}` },
  { label: 'RSS', href: '/rss.xml' },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="site-footer">
  <div class="inner">
    <p>&copy; {year} {AUTHOR}</p>
    <ul class="links">
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 1.5rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .inner p {
    margin: 0;
  }
  .links {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
