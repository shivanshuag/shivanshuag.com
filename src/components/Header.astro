---
import { SITE_TITLE, NAV_LINKS } from '../consts';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <nav class="nav">
    <a href="/" class="brand">{SITE_TITLE}</a>
    <ul class="links">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class:list={[{ active: isActive(link.href) }]}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
  }
  .nav {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
  }
  .brand:hover {
    text-decoration: none;
    color: var(--accent);
  }
  .links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .links a:hover,
  .links a.active {
    color: var(--text);
    text-decoration: none;
  }
  .links a.active {
    font-weight: 600;
  }
</style>
