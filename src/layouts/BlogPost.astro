---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } =
  Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="updated">
              (updated <FormattedDate date={updatedDate} />)
            </span>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((tag) => (
              <li>#{tag}</li>
            ))}
          </ul>
        )
      }
    </header>
    {heroImage && <img class="hero" src={heroImage} alt="" />}
    <div class="prose">
      <slot />
    </div>
  </article>
  <p class="back"><a href="/blog">&larr; Back to all posts</a></p>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
  }
  .post-header h1 {
    margin-bottom: 0.5rem;
  }
  .meta {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .updated {
    margin-left: 0.4rem;
    font-style: italic;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .hero {
    width: 100%;
    margin-bottom: 2rem;
  }
  .back {
    margin-top: 3rem;
  }
</style>
